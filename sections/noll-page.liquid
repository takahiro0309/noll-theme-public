{% comment %} noll Page — generic content page wrapper — bilingual {% endcomment %}

<div class="page-shell">
  <nav class="crumbs" aria-label="breadcrumb">
    <a href="{{ routes.root_url }}" data-en="Home">Home</a><span>/</span>{{ page.title }}
  </nav>

  <article style="max-width:720px; margin: 0 auto;">
    <h1 class="reveal" style="font-family: var(--font-heading--family, 'Figtree', sans-serif); font-size: 36px; font-weight: 500; letter-spacing: -0.02em; margin-bottom: 32px;">
      {{ page.title }}
    </h1>
    <div class="article">
      {{ page.content }}
    </div>
  </article>
</div>

{% schema %}
{
  "name": "noll Page",
  "presets": [{ "name": "noll Page" }]
}
{% endschema %}
