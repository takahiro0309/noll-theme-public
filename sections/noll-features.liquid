{% comment %} noll Features — 3 feature cards (number + image + body) — bilingual {% endcomment %}

<section class="features" id="{{ section.settings.anchor | default: 'features' }}">
  <div class="features__head">
    <p class="eyebrow reveal" data-en="{{ section.settings.eyebrow_en | default: 'Why noll' | escape }}">{{ section.settings.eyebrow | default: 'Why noll' }}</p>
    <h2 class="features__title reveal" data-reveal-delay="1" data-en="{{ section.settings.title_en | default: 'Align body and mind from your very first step.' | escape }}">{{ section.settings.title | default: '日常の一歩から、身体と思考を整える。' }}</h2>
    <p class="features__intro reveal" data-reveal-delay="2" data-en="{{ section.settings.intro_en | default: 'Structural design that never restricts natural foot movement. Three essentials for a conditioning lifestyle.' | escape }}">{{ section.settings.intro | default: '足本来の動きを妨げない構造設計。コンディショニングする毎日へ、3つの本質。' }}</p>
  </div>
  <div class="features__grid">
    {%- for block in section.blocks -%}
      <article class="feature reveal"{% if forloop.index0 > 0 %} data-reveal-delay="{{ forloop.index0 }}"{% endif %} {{ block.shopify_attributes }}>
        <div class="feature__img">
          {%- if block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 800 }}" alt="">
          {%- else -%}
            <img src="{{ block.settings.fallback_image | default: 'journal_1.jpg' | asset_url }}" alt="">
          {%- endif -%}
        </div>
        <div class="feature__text">
          <span class="feature__num">{{ block.settings.number | default: forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          <h3 class="feature__title" data-en="{{ block.settings.title_en | escape }}">{{ block.settings.title }}</h3>
          <p class="feature__body" data-en="{{ block.settings.body_en | escape }}">{{ block.settings.body }}</p>
        </div>
      </article>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "noll Features",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anchor id", "default": "features" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (JA)", "default": "Why noll" },
    { "type": "text", "id": "eyebrow_en", "label": "Eyebrow (EN)", "default": "Why noll" },
    { "type": "text", "id": "title", "label": "Title (JA)", "default": "日常の一歩から、身体と思考を整える。" },
    { "type": "text", "id": "title_en", "label": "Title (EN)", "default": "Align body and mind from your very first step." },
    { "type": "textarea", "id": "intro", "label": "Intro (JA)", "default": "足本来の動きを妨げない構造設計。コンディショニングする毎日へ、3つの本質。" },
    { "type": "textarea", "id": "intro_en", "label": "Intro (EN)", "default": "Structural design that never restricts natural foot movement. Three essentials for a conditioning lifestyle." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "number", "label": "Number" },
        { "type": "text", "id": "title", "label": "Title (JA)" },
        { "type": "text", "id": "title_en", "label": "Title (EN)" },
        { "type": "textarea", "id": "body", "label": "Body (JA)" },
        { "type": "textarea", "id": "body_en", "label": "Body (EN)" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback asset filename" }
      ]
    }
  ],
  "presets": [
    {
      "name": "noll Features",
      "blocks": [
        { "type": "feature", "settings": { "number": "01", "title": "足本来の動きを妨げない。", "title_en": "Never restrict natural movement.", "body": "自由に動ける日常へ。広いラスト形状が横方向のブレを抑え、指先5本が独立して動く空間を確保。足首と膝の負担を逃がす。", "body_en": "Freedom in every step. The wide last shape reduces lateral sway while giving all five toes room to move independently. Relieves stress on ankles and knees.", "fallback_image": "journal_1.jpg" } },
        { "type": "feature", "settings": { "number": "02", "title": "足元から、姿勢を整える。", "title_en": "Align your posture from the ground up.", "body": "軸のある毎日へ。踵を包む3Dヒールクレードルが自然な体重移動を導く。1日2万歩でも疲労を蓄積させない設計。", "body_en": "A centered life, every day. The 3D heel cradle guides natural weight transfer. Designed to prevent fatigue accumulation even at 20,000 steps a day.", "fallback_image": "journal_2.jpg" } },
        { "type": "feature", "settings": { "number": "03", "title": "歩きが整う。思考が冴える。", "title_en": "Better walking. Sharper thinking.", "body": "中足部のフレックス溝が自然な蹴り出しを支える。歩行中の発散的思考の生産量は座位の60%増し。歩きが変われば、思考が変わる。", "body_en": "Midfoot flex grooves support natural toe-off. Divergent thinking output increases 60% while walking vs. sitting. Change how you walk, change how you think.", "fallback_image": "journal_3.jpg" } }
      ]
    }
  ]
}
{% endschema %}
