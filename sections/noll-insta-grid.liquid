{% comment %} noll Instagram grid — 5 image links {% endcomment %}

<section class="insta-grid"{% if section.settings.border_top %} style="border-top: 1px solid var(--c-line);"{% endif %}>
  <div class="insta-grid__inner">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: section.settings.handle_url }}" target="_blank" rel="noopener noreferrer" class="insta-grid__item reveal"{% if forloop.index0 > 0 %} data-reveal-delay="{{ forloop.index0 }}"{% endif %} data-cursor="view" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.alt | default: section.settings.handle | escape }}">
        {%- else -%}
          <img src="{{ block.settings.fallback_image | default: 'insta_1.jpg' | asset_url }}" alt="{{ section.settings.handle | escape }}">
        {%- endif -%}
      </a>
    {%- endfor -%}
  </div>
  <p class="insta-grid__handle"><a href="{{ section.settings.handle_url | default: 'https://www.instagram.com/noll_japan' }}" target="_blank" rel="noopener noreferrer">{{ section.settings.handle | default: '@noll_japan' }}</a></p>
</section>

{% schema %}
{
  "name": "noll Insta Grid",
  "settings": [
    { "type": "text", "id": "handle", "label": "Handle", "default": "@noll_japan" },
    { "type": "url", "id": "handle_url", "label": "Handle URL", "default": "https://www.instagram.com/noll_japan" },
    { "type": "checkbox", "id": "border_top", "label": "Show border top", "default": false }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback asset filename" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "alt", "label": "Alt text" }
      ]
    }
  ],
  "presets": [
    {
      "name": "noll Insta Grid",
      "blocks": [
        { "type": "tile", "settings": { "fallback_image": "insta_1.jpg" } },
        { "type": "tile", "settings": { "fallback_image": "insta_2.jpg" } },
        { "type": "tile", "settings": { "fallback_image": "insta_3.jpg" } },
        { "type": "tile", "settings": { "fallback_image": "insta_4.jpg" } },
        { "type": "tile", "settings": { "fallback_image": "insta_5.jpg" } }
      ]
    }
  ]
}
{% endschema %}
