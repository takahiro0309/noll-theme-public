{% comment %} noll Collection — editorial collection page (bilingual) {% endcomment %}

<section class="noll-collection">
  <nav class="crumbs" aria-label="breadcrumb">
    <a href="{{ routes.root_url }}" data-en="Home">Home</a><span>/</span>
    <span data-en="Shop">{{ collection.title | default: 'すべての商品' }}</span>
  </nav>

  <header class="noll-collection__head">
    <p class="eyebrow reveal" data-en="{{ section.settings.eyebrow_en | default: 'Collection' | escape }}">{{ section.settings.eyebrow | default: 'コレクション' }}</p>
    <h1 class="noll-collection__title reveal" data-reveal-delay="1">{{ collection.title | default: 'noll Collection' }}</h1>
    {%- if collection.description != blank -%}
      <p class="noll-collection__desc reveal" data-reveal-delay="2">{{ collection.description | strip_html | truncate: 180 }}</p>
    {%- else -%}
      <p class="noll-collection__desc reveal" data-reveal-delay="2" data-en="{{ section.settings.intro_en | default: 'Performance footgear, designed for walking. Crafted in Japan, built for the everyday.' | escape }}">{{ section.settings.intro | default: '歩くために設計された、パフォーマンス・フットギア。日本の小ロット製造、毎日のための一足。' }}</p>
    {%- endif -%}
  </header>

  <div class="noll-collection__toolbar reveal" data-reveal-delay="2">
    <p class="noll-collection__count" data-en="{{ collection.products_count }} {{ section.settings.result_label_en | default: 'product{% if collection.products_count != 1 %}s{% endif %}' | escape }}">{{ section.settings.result_label | default: '商品数' }} {{ collection.products_count }}{{ section.settings.unit | default: '点' }}</p>
    <div class="noll-collection__sort">
      <label for="sort-by" class="noll-collection__sort-label" data-en="Sort by">並び順</label>
      <select id="sort-by" aria-label="Sort">
        <option value="manual" data-en="Featured">人気順</option>
        <option value="created-descending" data-en="Newest">新着順</option>
        <option value="price-ascending" data-en="Price: Low to High">価格: 安い順</option>
        <option value="price-descending" data-en="Price: High to Low">価格: 高い順</option>
      </select>
    </div>
  </div>

  {%- if collection.products_count > 0 -%}
    <div class="noll-collection__grid">
      {%- for product in collection.products -%}
        {%- assign vfor = product.selected_or_first_available_variant -%}
        <a href="{{ product.url }}" class="pcard reveal" data-reveal-delay="{{ forloop.index | modulo: 4 }}" data-cursor="view">
          <div class="pcard__media">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.title | escape }}">
            {%- else -%}
              <img src="{{ 'product_main.jpg' | asset_url }}" alt="{{ product.title | escape }}">
            {%- endif -%}
            {%- if product.compare_at_price > product.price -%}
              <span class="pcard__badge" data-en="Sale">セール</span>
            {%- elsif product.tags contains 'new' or product.tags contains 'New' -%}
              <span class="pcard__badge pcard__badge--new" data-en="New">新作</span>
            {%- endif -%}
          </div>
          <div class="pcard__info">
            <p class="pcard__brand">NOLL</p>
            <h3 class="pcard__name">{{ product.title }}</h3>
            <div class="pcard__rating">
              <span class="pcard__stars">★★★★★</span>
              <span class="pcard__rating-text">{{ section.settings.rating_default | default: '4.8 / 5.0 · 128' }}</span>
            </div>
            <div class="pcard__price-row">
              <span class="pcard__price">{{ product.price | money }}</span>
              {%- if product.compare_at_price > product.price -%}
                <span class="pcard__compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
            </div>
            <p class="pcard__tax" data-en="{{ section.settings.tax_label_en | default: 'Tax incl. · Free shipping in Japan' | escape }}">{{ section.settings.tax_label | default: '税込 · 国内送料無料' }}</p>
            {%- if product.options.size > 0 and product.options.first == 'カラー' -%}
              <div class="pcard__swatches" aria-label="Available colors">
                {%- for value in product.options_by_name['カラー'].values | default: product.options_with_values.first.values -%}
                  {%- assign sw = '#111' -%}
                  {%- if value contains 'White' or value contains 'Ivory' -%}{%- assign sw = '#f5f1e8' -%}{%- endif -%}
                  {%- if value contains 'Olive' -%}{%- assign sw = '#5a6a3f' -%}{%- endif -%}
                  <span class="pcard__swatch" style="--swatch:{{ sw }};" title="{{ value }}"></span>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if collection.products_count > 12 -%}
      <div class="noll-collection__pagination">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}
  {%- else -%}
    <div class="noll-collection__empty">
      <p data-en="No products found in this collection.">この条件では商品が見つかりませんでした。</p>
      <a href="{{ routes.all_products_collection_url }}" class="btn btn--solid-dark" data-en="View all products →">すべての商品を見る →</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "noll Collection",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow (JA)", "default": "コレクション" },
    { "type": "text", "id": "eyebrow_en", "label": "Eyebrow (EN)", "default": "Collection" },
    { "type": "textarea", "id": "intro", "label": "Default intro (JA)", "default": "歩くために設計された、パフォーマンス・フットギア。日本の小ロット製造、毎日のための一足。" },
    { "type": "textarea", "id": "intro_en", "label": "Default intro (EN)", "default": "Performance footgear, designed for walking. Crafted in Japan, built for the everyday." },
    { "type": "text", "id": "result_label", "label": "Count label (JA)", "default": "商品数" },
    { "type": "text", "id": "result_label_en", "label": "Count label (EN)", "default": "products" },
    { "type": "text", "id": "unit", "label": "Unit (JA)", "default": "点" },
    { "type": "text", "id": "rating_default", "label": "Rating default", "default": "4.8 / 5.0 · 128" },
    { "type": "text", "id": "tax_label", "label": "Tax label (JA)", "default": "税込 · 国内送料無料" },
    { "type": "text", "id": "tax_label_en", "label": "Tax label (EN)", "default": "Tax incl. · Free shipping in Japan" }
  ],
  "presets": [{ "name": "noll Collection" }]
}
{% endschema %}
