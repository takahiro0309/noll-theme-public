{% comment %} noll Product angles strip — 4 image cards linking to PDP (bilingual labels) {% endcomment %}

<section class="product-angles-strip">
  <div class="product-angles">
    {%- for block in section.blocks -%}
      <a href="{{ block.settings.link | default: section.settings.product_url }}" class="product-angles__item reveal"{% if forloop.index0 > 0 %} data-reveal-delay="{{ forloop.index0 }}"{% endif %} data-cursor="view" {{ block.shopify_attributes }}>
        {%- if block.settings.image != blank -%}
          <img src="{{ block.settings.image | image_url: width: 600 }}" alt="{{ block.settings.label | escape }}">
        {%- else -%}
          <img src="{{ block.settings.fallback_image | default: 'product_angle_1.jpg' | asset_url }}" alt="{{ block.settings.label | escape }}">
        {%- endif -%}
        <span data-en="{{ block.settings.label_en | escape }}">{{ block.settings.label }}</span>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "noll Product Angles",
  "settings": [
    { "type": "url", "id": "product_url", "label": "Default product link" }
  ],
  "blocks": [
    {
      "type": "angle",
      "name": "Angle",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback asset filename", "info": "e.g. product_angle_1.jpg" },
        { "type": "text", "id": "label", "label": "Label (JA)" },
        { "type": "text", "id": "label_en", "label": "Label (EN)" },
        { "type": "url", "id": "link", "label": "Link override" }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "noll Product Angles",
      "blocks": [
        { "type": "angle", "settings": { "label": "解剖学的ラスト", "label_en": "Anatomical Last", "fallback_image": "product_angle_1.jpg" } },
        { "type": "angle", "settings": { "label": "3Dクレードル", "label_en": "3D Cradle", "fallback_image": "product_angle_2.jpg" } },
        { "type": "angle", "settings": { "label": "フレックス溝", "label_en": "Flex Grooves", "fallback_image": "product_angle_3.jpg" } },
        { "type": "angle", "settings": { "label": "軽量ミッドソール", "label_en": "Lightweight Midsole", "fallback_image": "product_angle_4.jpg" } }
      ]
    }
  ]
}
{% endschema %}
