{% comment %} noll Blog (Journal) — article list — bilingual {% endcomment %}

<nav class="crumbs" aria-label="breadcrumb">
  <a href="{{ routes.root_url }}" data-en="Home">Home</a><span>/</span>
  <span data-en="Journal">Journal</span>
</nav>

{%- assign main = blog.articles.first -%}
{%- if main -%}
  <article>
    <div class="journal-hero">
      <p class="journal-hero__cat reveal">Journal · {{ main.tags.first | default: 'Essay' }}</p>
      <h1 class="journal-hero__title reveal" data-reveal-delay="1">{{ main.title }}</h1>
      <div class="journal-hero__meta reveal" data-reveal-delay="2">
        {{ main.published_at | date: '%Y.%m.%d' }} · {{ main.author }}
      </div>
    </div>
    {%- if main.image != blank -%}
      <div class="journal-hero__media reveal">
        <div class="journal-hero__media-inner">
          <img src="{{ main.image | image_url: width: 1600 }}" alt="{{ main.title | escape }}">
        </div>
      </div>
    {%- endif -%}
    <div style="text-align:center; margin: 32px 0 64px;">
      <a href="{{ main.url }}" class="btn btn--solid-dark" data-en="{{ section.settings.read_cta_en | default: 'Read article →' | escape }}">{{ section.settings.read_cta | default: '記事を読む →' }}</a>
    </div>
  </article>
{%- endif -%}

<section class="journal-related">
  <h2 data-en="{{ section.settings.list_title_en | default: 'All Articles' | escape }}">{{ section.settings.list_title | default: 'すべての記事' }}</h2>
  <div class="journal-related__grid">
    {%- for art in blog.articles offset: 1 limit: 12 -%}
      <a href="{{ art.url }}" class="journal-card reveal"{% if forloop.index0 > 0 %} data-reveal-delay="{{ forloop.index0 }}"{% endif %} data-cursor="view">
        {%- if art.image -%}
          <div class="journal-card__media"><img src="{{ art.image | image_url: width: 800 }}" alt="{{ art.title | escape }}"></div>
        {%- endif -%}
        <p class="journal-card__cat">{{ art.tags.first | default: 'Journal' }}</p>
        <h3 class="journal-card__title">{{ art.title }}</h3>
        <p class="journal-card__date">{{ art.published_at | date: '%Y.%m.%d' }}</p>
      </a>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "noll Blog",
  "settings": [
    { "type": "text", "id": "list_title", "label": "List title (JA)", "default": "すべての記事" },
    { "type": "text", "id": "list_title_en", "label": "List title (EN)", "default": "All Articles" },
    { "type": "text", "id": "read_cta", "label": "Read article CTA (JA)", "default": "記事を読む →" },
    { "type": "text", "id": "read_cta_en", "label": "Read article CTA (EN)", "default": "Read article →" }
  ],
  "presets": [{ "name": "noll Blog" }]
}
{% endschema %}
