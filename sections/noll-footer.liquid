{% comment %}
  noll Footer — bilingual
  4 column links + brand + social + bottom row.
{% endcomment %}

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__top">
      <div>
        <p class="site-footer__brand">{{ section.settings.brand_name | default: 'noll' }}</p>
        <p class="site-footer__tag" data-en="{{ section.settings.brand_tag_en | default: 'Performance footgear / A footgear brand that sharpens your mind. Coming June 2026.' | escape }}">{{ section.settings.brand_tag | default: 'Performance footgear / 思考を研ぎ澄ますフットギア・ブランド。Coming June 2026.' }}</p>
        <div class="site-footer__social">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.x != blank -%}
            <a href="{{ section.settings.x }}" target="_blank" rel="noopener noreferrer" aria-label="X">
              <svg viewBox="0 0 24 24"><path d="M4 4 L 20 20 M 20 4 L 4 20"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.youtube != blank -%}
            <a href="{{ section.settings.youtube }}" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg viewBox="0 0 24 24"><rect x="3" y="6" width="18" height="12" rx="3"/><polygon points="11,9 15,12 11,15" fill="currentColor"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4 data-en="{{ block.settings.title_en | escape }}">{{ block.settings.title }}</h4>
            <ul>
              {%- assign list = linklists[block.settings.menu] -%}
              {%- if list != blank -%}
                {%- for link in list.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              {%- endif -%}
            </ul>
          </div>
        {%- endif -%}
        {%- if block.type == 'static_column' -%}
          <div class="site-footer__col" {{ block.shopify_attributes }}>
            <h4 data-en="{{ block.settings.title_en | escape }}">{{ block.settings.title }}</h4>
            <ul>
              {%- if block.settings.link_1_text != blank -%}<li><a href="{{ block.settings.link_1_url | default: '#' }}" data-en="{{ block.settings.link_1_text_en | escape }}">{{ block.settings.link_1_text }}</a></li>{%- endif -%}
              {%- if block.settings.link_2_text != blank -%}<li><a href="{{ block.settings.link_2_url | default: '#' }}" data-en="{{ block.settings.link_2_text_en | escape }}">{{ block.settings.link_2_text }}</a></li>{%- endif -%}
              {%- if block.settings.link_3_text != blank -%}<li><a href="{{ block.settings.link_3_url | default: '#' }}" data-en="{{ block.settings.link_3_text_en | escape }}">{{ block.settings.link_3_text }}</a></li>{%- endif -%}
              {%- if block.settings.link_4_text != blank -%}<li><a href="{{ block.settings.link_4_url | default: '#' }}" data-en="{{ block.settings.link_4_text_en | escape }}">{{ block.settings.link_4_text }}</a></li>{%- endif -%}
            </ul>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="site-footer__bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      <span data-en="{{ section.settings.locale_label_en | default: 'Japan / JPY ¥ — English' | escape }}">{{ section.settings.locale_label | default: '日本 / JPY ¥ — 日本語' }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "noll Footer",
  "settings": [
    { "type": "text", "id": "brand_name", "label": "Brand name", "default": "noll" },
    { "type": "textarea", "id": "brand_tag", "label": "Brand tagline (JA)", "default": "Performance footgear / 思考を研ぎ澄ますフットギア・ブランド。Coming June 2026." },
    { "type": "textarea", "id": "brand_tag_en", "label": "Brand tagline (EN)", "default": "Performance footgear / A footgear brand that sharpens your mind. Coming June 2026." },
    { "type": "header", "content": "Social" },
    { "type": "url", "id": "instagram", "label": "Instagram URL", "default": "https://www.instagram.com/noll_japan" },
    { "type": "url", "id": "x", "label": "X URL" },
    { "type": "url", "id": "youtube", "label": "YouTube URL" },
    { "type": "header", "content": "Bottom" },
    { "type": "text", "id": "locale_label", "label": "Locale label (JA)", "default": "日本 / JPY ¥ — 日本語" },
    { "type": "text", "id": "locale_label_en", "label": "Locale label (EN)", "default": "Japan / JPY ¥ — English" }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Menu link column",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading (JA)", "default": "Shop" },
        { "type": "text", "id": "title_en", "label": "Heading (EN)", "default": "Shop" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "static_column",
      "name": "Static link column",
      "settings": [
        { "type": "text", "id": "title", "label": "Heading (JA)", "default": "Support" },
        { "type": "text", "id": "title_en", "label": "Heading (EN)", "default": "Support" },
        { "type": "text", "id": "link_1_text", "label": "Link 1 (JA)" },
        { "type": "text", "id": "link_1_text_en", "label": "Link 1 (EN)" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_text", "label": "Link 2 (JA)" },
        { "type": "text", "id": "link_2_text_en", "label": "Link 2 (EN)" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_text", "label": "Link 3 (JA)" },
        { "type": "text", "id": "link_3_text_en", "label": "Link 3 (EN)" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_text", "label": "Link 4 (JA)" },
        { "type": "text", "id": "link_4_text_en", "label": "Link 4 (EN)" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "noll Footer",
      "blocks": [
        { "type": "link_column", "settings": { "title": "Shop", "title_en": "Shop", "menu": "footer" } },
        { "type": "link_column", "settings": { "title": "Brand", "title_en": "Brand" } },
        { "type": "static_column", "settings": { "title": "Support", "title_en": "Support", "link_1_text": "配送について", "link_1_text_en": "Shipping", "link_1_url": "/pages/contact-us", "link_2_text": "返品・交換", "link_2_text_en": "Returns & Exchanges", "link_2_url": "/pages/contact-us", "link_3_text": "サイズガイド", "link_3_text_en": "Size Guide", "link_3_url": "/pages/contact-us" } },
        { "type": "static_column", "settings": { "title": "Legal", "title_en": "Legal", "link_1_text": "利用規約", "link_1_text_en": "Terms of Service", "link_1_url": "/policies/terms-of-service", "link_2_text": "プライバシーポリシー", "link_2_text_en": "Privacy Policy", "link_2_url": "/policies/privacy-policy", "link_3_text": "特定商取引法", "link_3_text_en": "Commerce Law", "link_3_url": "/policies/legal-notice" } }
      ]
    }
  ]
}
{% endschema %}
