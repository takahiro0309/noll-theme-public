{% comment %} noll News strip — newsletter signup — bilingual {% endcomment %}

<section class="news-strip" id="{{ section.settings.anchor | default: 'contact' }}"{% if section.settings.margin_top %} style="margin-top:40px;"{% endif %}>
  <div class="news-strip__inner">
    <div class="news-strip__copy">
      <h3 data-en="{{ section.settings.title_en | default: 'noll Letter — Insights for Walkers' | escape }}">{{ section.settings.title | default: 'noll Letter — 歩く人のためのインサイト' }}</h3>
      <p data-en="{{ section.settings.body_en | default: 'Monthly updates on walking & thinking research, health & conditioning tips, and new store openings.' | escape }}">{{ section.settings.body | default: '歩行と思考の最新リサーチ、健康・コンディショニング情報、新店舗オープン情報を月1回お届けします。' }}</p>
    </div>
    {%- form 'customer', class: 'news-strip__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input
        type="email"
        name="contact[email]"
        required
        placeholder="{{ section.settings.placeholder | default: 'メールアドレスを入力' }}"
        data-en-placeholder="{{ section.settings.placeholder_en | default: 'Enter your email' | escape }}"
        aria-label="email"
      >
      <button type="submit" data-en="{{ section.settings.submit_en | default: 'Subscribe' | escape }}">{%- if form.posted_successfully? -%}{{ section.settings.thanks | default: '✓ Thanks' }}{%- else -%}{{ section.settings.submit | default: '登録する' }}{%- endif -%}</button>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "noll News Strip",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anchor id", "default": "contact" },
    { "type": "text", "id": "title", "label": "Title (JA)", "default": "noll Letter — 歩く人のためのインサイト" },
    { "type": "text", "id": "title_en", "label": "Title (EN)", "default": "noll Letter — Insights for Walkers" },
    { "type": "textarea", "id": "body", "label": "Body (JA)", "default": "歩行と思考の最新リサーチ、健康・コンディショニング情報、新店舗オープン情報を月1回お届けします。" },
    { "type": "textarea", "id": "body_en", "label": "Body (EN)", "default": "Monthly updates on walking & thinking research, health & conditioning tips, and new store openings." },
    { "type": "text", "id": "placeholder", "label": "Placeholder (JA)", "default": "メールアドレスを入力" },
    { "type": "text", "id": "placeholder_en", "label": "Placeholder (EN)", "default": "Enter your email" },
    { "type": "text", "id": "submit", "label": "Submit text (JA)", "default": "登録する" },
    { "type": "text", "id": "submit_en", "label": "Submit text (EN)", "default": "Subscribe" },
    { "type": "text", "id": "thanks", "label": "Thanks text", "default": "✓ Thanks" },
    { "type": "checkbox", "id": "margin_top", "label": "Add top margin", "default": false }
  ],
  "presets": [{ "name": "noll News Strip" }]
}
{% endschema %}
